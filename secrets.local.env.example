# One-time bootstrap input. Copy to secrets.local.env, fill in the values, then
# run the "Manage secrets" item in workshop.py to push them to Secret Manager.
# DELETE secrets.local.env afterward — the values then live only in Secret
# Manager. (secrets.local.env is gitignored so it can never be committed.)
#
# Keys MUST match the env-var names in workshop.config.json.

HARNESS_ACCOUNT_ID=your_harness_account_id
HARNESS_PLATFORM_API_KEY=pat.xxxxx.xxxxx.xxxxx

TF_VAR_billing_account=0123AB-4567CD-89EF01
TF_VAR_parent=organizations/123456789

# Terraform list-typed variables are parsed from the env var as HCL/JSON:
TF_VAR_attendee_emails=["alice.smith@example.com","bob.jones@example.com"]

# Administrators/instructors: granted roles/editor on EVERY attendee project,
# but given no project of their own. Optional — omit for none.
TF_VAR_shared_editor_emails=["admin@example.com"]

# Copy to terraform.tfvars and fill in your values.

parent          = "organizations/123456789" # "organizations/<id>" or "folders/<id>"
billing_account = "0123AB-4567CD-89EF01"    # your billing account ID
prefix          = "workshop"

# Local part must be first.last; project names are derived as firstlast.
attendee_emails = [
  "alice.smith@example.com",
  "bob.jones@example.com",
  "carol.diaz@example.com",
]

# Instructors/operators: editor on every project above, no project of their own.
# shared_editor_emails = [
#   "instructor@example.com",
# ]

# Copy to terraform.tfvars and fill in.
#
# parent and billing_account normally come from Secret Manager via workshop.py
# (TF_VAR_parent / TF_VAR_billing_account) — leave them unset when running that
# way. Uncomment to set explicitly for a bare `tofu` run:
# parent          = "organizations/123456789"
# billing_account = "0123AB-4567CD-89EF01"

region = "us-central1"
zone   = "us-central1-a"
prefix = "zap"

# REQUIRED: who may reach the ZAP API port. A reachable ZAP daemon can scan/proxy
# arbitrary targets, so keep this tight. Use ["0.0.0.0/0"] only for a fully-open,
# short-lived workshop.
allowed_source_ranges = [
  # "203.0.113.10/32",
]

zap_port    = 8080
preemptible = false
# zap_api_key = "set-your-own-or-leave-unset-to-auto-generate"
# zap_image   = "ghcr.io/zaproxy/zaproxy:2.15.0"   # pin a version for reproducibility

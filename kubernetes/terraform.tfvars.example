# Copy to terraform.tfvars and fill in your values.

region = "us-central1"
zone   = "us-central1-a"
prefix = "workshop"

# attendee_projects is auto-populated from the projects/ factory layer's state
# (see data.tf), so normally you leave it unset. Uncomment only to override with
# projects created outside that layer (key = attendee id, value = project ID):
# attendee_projects = {
#   alice = "ws-alice-1234"
#   bob   = "ws-bob-5678"
# }

# Workshop-friendly defaults (cheap, interruptible):
preemptible    = true
machine_type   = "e2-standard-2"
node_count     = 1
max_node_count = 2
